<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RustSensei" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/rust_orange</item>
        <item name="colorPrimaryVariant">@color/rust_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/rust_orange_light</item>
        <item name="colorSecondaryVariant">@color/rust_orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Splash screen (androidx.core:core-splashscreen). Shows the launcher
         icon on the brand background, then hands off to Theme.RustSensei. -->
    <style name="Theme.RustSensei.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Syltech company wordmark at the bottom of the splash (API 31+; older ignores). -->
        <item name="android:windowSplashScreenBrandingImage">@drawable/syltech_wordmark</item>
        <item name="postSplashScreenTheme">@style/Theme.RustSensei</item>
    </style>
</resources>
